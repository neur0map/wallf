#!/bin/bash
# wallf — wallhaven.cc wallpaper fetcher for I.A.M
# Interactive TUI with gum, or non-interactive with arguments.
# Downloads to ~/Pictures/Wallpapers and refreshes skwd cache.

WALL_DIR="${HOME}/Pictures/Wallpapers"
API="https://wallhaven.cc/api/v1/search"
SKWD_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/skwd/wallpaper"
ATLEAST="2560x1440"

# Interactive mode (no args)
if [[ $# -eq 0 ]] && command -v gum >/dev/null 2>&1; then
    QUERY=$(gum input --placeholder "Search wallhaven.cc..." --prompt "  " --width 50 --char-limit 100)
    [ -z "$QUERY" ] && exit 0

    SORT=$(gum choose --header "Sort by:" "toplist" "random" "views" "favorites" "date_added")
    COUNT=$(gum input --placeholder "5" --prompt " How many: " --value "5" --width 20)
    COUNT=${COUNT:-5}

    CATEGORIES=$(gum choose --header "Categories:" --no-limit "general" "anime" "people")
    CAT_BITS="000"
    echo "$CATEGORIES" | grep -q "general" && CAT_BITS="${CAT_BITS:0:0}1${CAT_BITS:1}"
    echo "$CATEGORIES" | grep -q "anime"   && CAT_BITS="${CAT_BITS:0:1}1${CAT_BITS:2}"
    echo "$CATEGORIES" | grep -q "people"  && CAT_BITS="${CAT_BITS:0:2}1"
    [ "$CAT_BITS" = "000" ] && CAT_BITS="110"

    RANGE="1M"
    if [ "$SORT" = "toplist" ]; then
        RANGE=$(gum choose --header "Time range:" "1d" "3d" "1w" "1M" "3M" "6M" "1y")
    fi
else
    # Non-interactive mode
    COUNT=5
    SORT="toplist"
    RANGE="1M"
    QUERY=""
    CAT_BITS="110"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --count|-n) COUNT="$2"; shift 2 ;;
            --sort|-s) SORT="$2"; shift 2 ;;
            --range|-r) RANGE="$2"; shift 2 ;;
            --categories) CAT_BITS="$2"; shift 2 ;;
            --help|-h)
                echo "wallf — wallhaven.cc wallpaper fetcher"
                echo ""
                echo "Usage: wallf [query] [options]"
                echo "       wallf                    (interactive TUI)"
                echo ""
                echo "Options:"
                echo "  --count, -n N     Number to download (default: 5)"
                echo "  --sort, -s MODE   toplist, random, views, favorites (default: toplist)"
                echo "  --range, -r RANGE 1d, 3d, 1w, 1M, 3M, 6M, 1y (default: 1M)"
                echo "  --categories C    110=general+anime (default), 111=all"
                exit 0 ;;
            *) QUERY="$QUERY $1"; shift ;;
        esac
    done
    QUERY="$(echo "$QUERY" | xargs)"
fi

mkdir -p "$WALL_DIR"

# Build hash index of existing wallpapers for content dedup
HASH_INDEX=$(mktemp)
find "$WALL_DIR" -maxdepth 1 -type f \( -name '*.jpg' -o -name '*.jpeg' -o -name '*.png' -o -name '*.webp' \) -exec md5sum {} \; 2>/dev/null | awk '{print $1}' | sort -u > "$HASH_INDEX"

# Build API URL
URL="${API}?categories=${CAT_BITS}&purity=100&sorting=${SORT}&atleast=${ATLEAST}"
if [ -n "$QUERY" ]; then
    ENCODED=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY")
    URL="${URL}&q=${ENCODED}"
fi
[ "$SORT" = "toplist" ] && URL="${URL}&topRange=${RANGE}"

echo ""
echo "  Searching wallhaven.cc: ${QUERY} (${SORT})"

RESULT=$(curl -s "$URL")
TOTAL=$(echo "$RESULT" | jq -r '.meta.total // 0')

if [ "$TOTAL" = "0" ] || [ "$TOTAL" = "null" ]; then
    echo "  No results found."
    exit 0
fi

echo "  Found ${TOTAL} results. Downloading ${COUNT}..."
echo ""

DOWNLOADED=0
echo "$RESULT" | jq -r '.data[] | "\(.path)\t\(.resolution)\t\(.views)"' | head -n "$COUNT" | while IFS=$'\t' read -r IMG_URL RES VIEWS; do
    FILENAME=$(basename "$IMG_URL")
    if [ -f "${WALL_DIR}/${FILENAME}" ]; then
        echo "  skip  ${FILENAME} (exists)"
        continue
    fi
    # Download to temp, check content hash for duplicates
    TMPFILE=$(mktemp)
    curl -s -o "$TMPFILE" "$IMG_URL"
    HASH=$(md5sum "$TMPFILE" | awk '{print $1}')
    if grep -q "$HASH" "$HASH_INDEX"; then
        echo "  skip  ${FILENAME} (duplicate content)"
        rm -f "$TMPFILE"
        continue
    fi
    mv "$TMPFILE" "${WALL_DIR}/${FILENAME}"
    echo "$HASH" >> "$HASH_INDEX"
    echo "  fetch ${FILENAME}  ${RES}  ${VIEWS} views"
    DOWNLOADED=$((DOWNLOADED + 1))
done
rm -f "$HASH_INDEX"

# Invalidate skwd cache so new wallpapers appear on next open
rm -f "$SKWD_CACHE/checksum.txt" 2>/dev/null

echo ""
echo "  Done. Open wallpaper selector (Super+Shift+W) to browse."
echo ""
